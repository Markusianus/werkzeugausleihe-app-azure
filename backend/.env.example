# Azure PostgreSQL Configuration
DB_HOST=your-server.postgres.database.azure.com
DB_PORT=5432
DB_NAME=toolhub
DB_USER=your-admin-user
DB_PASSWORD=your-password
DB_SSL=true

# Server Configuration
PORT=3000
NODE_ENV=production
REQUEST_BODY_LIMIT=2mb
MAX_IMAGE_BYTES=2097152
RATE_LIMIT_WINDOW_MS=15m
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=15m
AUTH_RATE_LIMIT_MAX=10
ADMIN_RATE_LIMIT_WINDOW_MS=5m
ADMIN_RATE_LIMIT_MAX=60

# CORS / Trusted Origins
FRONTEND_URL=https://your-webapp.azurewebsites.net
ALLOWED_ORIGINS=
TRUST_PROXY=1

# Admin Password / Token-Setup
ADMIN_PASSWORD=admin123
ADMIN_TOKEN_SECRET=change-me-in-staging
ADMIN_TOKEN_TTL_HOURS=12

# E-Mail / SMTP (optional; wenn leer, läuft ToolHub ohne Mailversand)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_AUTH=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_ALLOW_SELF_SIGNED=false
MAIL_FROM=ToolHub <noreply@example.com>
MAIL_SUBJECT_PREFIX=[ToolHub]
MAIL_VERIFY_ON_START=false
MAIL_SEND_RESERVATION_CONFIRMATION=true
MAIL_SEND_CHECKOUT_CONFIRMATION=true
MAIL_SEND_RETURN_CONFIRMATION=true
MAIL_SEND_OVERDUE_DIGEST=true
MAIL_ADMIN_TO=
MAIL_OVERDUE_RECIPIENTS=
MAIL_ENABLE_OVERDUE_SCHEDULER=false
MAIL_OVERDUE_INTERVAL_HOURS=24
MAIL_OVERDUE_STARTUP_DELAY_MS=10000
APP_BASE_URL=
